                    </div>
                    <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 leading-snug">{tech.name}</h3>
                    <p class="text-[11px] text-zinc-500 dark:text-zinc-400 mt-1 leading-snug">{tech.description}</p>
