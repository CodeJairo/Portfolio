---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { Image } from "astro:assets";
import loginImage from "../../assets/pleroma/login.png";
import contractorFormImage from "../../assets/pleroma/contractor-form.png";
import cdpCreationImage from "../../assets/pleroma/cdp-creation.png";
import masterInfoImage from "../../assets/pleroma/master-info.png";
import auditsLogImage from "../../assets/pleroma/audits-log.png";
import documentGenerationImage from "../../assets/pleroma/document-generation.png";
import adminPanelImage from "../../assets/pleroma/admin-panel.png";
import PleromaHero from "../../components/projects/pleroma/PleromaHero.astro";
import PleromaLearnings from "../../components/projects/pleroma/PleromaLearnings.astro";
import PleromaFooter from "../../components/projects/pleroma/PleromaFooter.astro";

const DEPLOYMENT_URL = "https://pleroma-demo.example.com";

const techStack = [
  { name: "Angular 21+", category: "Frontend", description: "Interfaz principal" },
  { name: "TanStack Query", category: "Frontend", description: "Gestión de datos" },
  { name: "TailwindCSS", category: "Frontend", description: "Estilos utilitarios" },
  { name: "DaisyUI", category: "Frontend", description: "Componentes de interfaz" },
  { name: "Node.js 11+", category: "Backend", description: "Servicios de negocio" },
  { name: "Prisma ORM", category: "Backend", description: "Acceso a base de datos" },
  { name: "PostgreSQL", category: "Database", description: "Base de datos relacional" },
  { name: "AWS S3 / MinIO", category: "Storage", description: "Almacenamiento de archivos" },
  { name: "JWT", category: "Auth", description: "Access + Refresh Tokens" },
  { name: "DocxTemplater", category: "Docs", description: "Generación de documentos" },
  { name: "Docker", category: "DevOps", description: "Contenedores" },
];

const challenges = [
  { title: "Documentos manuales", description: "Creación manual de contratos, resoluciones y adendas propensa a errores humanos" },
  { title: "Control presupuestal fragmentado", description: "CDPs en hojas de cálculo sin trazabilidad con contratos" },
  { title: "Información dispersa", description: "Datos de contratistas en archivos físicos o digitales sin estructura" },
  { title: "Sin trazabilidad", description: "Falta de historial de versiones y auditoría de documentos" },
  { title: "Seguridad limitada", description: "Documentos sensibles sin control de acceso adecuado" },
];

const processSteps = [
  {
    step: 1,
    title: "Acceso y perfiles",
    description: "El sistema define perfiles de usuario y permisos por módulo para que cada persona vea y gestione solo lo que le corresponde.",
    image: loginImage,
    features: ["Ingreso seguro", "Perfiles de usuario", "Permisos por módulo", "Control de sesiones"]
  },
  {
    step: 2,
    title: "Registro de Terceros",
    description: "El módulo de terceros diferencia entre personas naturales y jurídicas. Cada tipo tiene formularios específicos con validación de documentos de identidad, datos bancarios y toda la información requerida para la contratación pública colombiana.",
    image: contractorFormImage,
    features: ["Persona natural y jurídica", "Validación automática de documentos", "Gestión de datos bancarios", "Datos requeridos por normativa colombiana"]
  },
  {
    step: 3,
    title: "Creación de CDP",
    description: "El Certificado de Disponibilidad Presupuestal (CDP) permite asignar rubros presupuestales con montos específicos. El sistema calcula automáticamente el total y valida que los montos sean consistentes antes de vincularlos a contratos.",
    image: cdpCreationImage,
    features: ["Múltiples rubros presupuestales", "Cálculo automático del total", "Validación de consistencia", "Vinculación directa a contratos"]
  },
  {
    step: 4,
    title: "Contrato — Información Maestra",
    description: "Este es el formulario central del sistema. Vincula el CDP con el tercero, define modalidad, fechas, valores, forma de pago, supervisor asignado y configuración de garantías requeridas según la normativa colombiana.",
    image: masterInfoImage,
    features: ["Vinculación CDP + Tercero", "Definición de modalidad y fechas", "Configuración de garantías", "Asignación de supervisor"]
  },
  {
    step: 5,
    title: "Generación de Documentos",
    description: "El módulo permite generar contratos y resoluciones en Word con datos del sistema, evitando edición manual repetitiva y errores de copia.",
    image: documentGenerationImage,
    features: ["Plantillas .docx personalizables", "Inyección automática de datos", "Conversión de cifras a letras", "Descarga individual o en lote (ZIP)"]
  },
  {
    step: 6,
    title: "Auditoría completa",
    description: "Cada acción relevante del sistema se registra en un log de auditoría con usuario, fecha y detalle. Esto permite seguir cambios en contratos, CDPs y terceros, y revisar el historial cuando se necesita.",
    image: auditsLogImage,
    features: ["Registro de usuario, fecha y acción", "Trazabilidad total de cambios", "Historial completo de modificaciones", "Auditoría de contratos, CDPs y terceros"]
  },
  {
    step: 7,
    title: "Configuración de Empresa",
    description: "Cada entidad configura su información institucional, plantillas y parámetros operativos, manteniendo sus datos separados de otras organizaciones.",
    image: adminPanelImage,
    features: ["Datos institucionales editables", "Gestión de plantillas", "Configuración por entidad", "Separación de información por organización"]
  }
];

const skills = [
  "Desarrollo full stack orientado a procesos administrativos",
  "Diseño de flujos para gestión contractual",
  "Generación automática de documentos a partir de datos del sistema",
  "Organización de información con base de datos relacional",
  "Control de acceso por perfiles de usuario",
  "Gestión de archivos y soportes del proceso",
];

const complianceStages = [
  { id: "register", step: 1, label: "Registro de Tercero", description: "Alta de persona natural o jurídica con documentación legal completa", controlPoint: "Validación documental", iconPath: "M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" },
  { id: "cdp", step: 2, label: "Certificado Presupuestal (CDP)", description: "Reserva de rubros presupuestales con cálculo automático y validación de montos", controlPoint: "Consistencia presupuestal", iconPath: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" },
  { id: "contract", step: 3, label: "Expediente Contractual", description: "Vinculación CDP + Tercero, definición de modalidad, fechas, valores y garantías", controlPoint: "Completitud del expediente", iconPath: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
  { id: "document", step: 4, label: "Generación Documental", description: "Producción automática de contratos, resoluciones y adendas en formato Word", controlPoint: "Integridad de plantilla", iconPath: "M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" },
  { id: "review", step: 5, label: "Revisión y Firma", description: "Envío por correo, historial de versiones con trazabilidad por usuario y fecha", controlPoint: "Auditoría de versiones", iconPath: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
  { id: "archive", step: 6, label: "Archivo y Auditoría", description: "Almacenamiento en S3/MinIO, logs de auditoría y acceso controlado por permisos", controlPoint: "Retención y trazabilidad", iconPath: "M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" },
];

const traceEvents = [
  { time: "08:12", action: "Validación de tercero", artifact: "EXP-302", status: "OK" },
  { time: "09:34", action: "Asociación de CDP", artifact: "CDP-118", status: "OK" },
  { time: "10:27", action: "Generación de contrato", artifact: "CON-77", status: "OK" },
  { time: "11:05", action: "Nueva versión de documento", artifact: "v2.1", status: "Revisado" },
];

const controlMatrix = [
  { stage: "register", control: "Documentos de identidad y soportes completos", area: "Contratación" },
  { stage: "cdp", control: "Montos consistentes con rubros presupuestales", area: "Financiera" },
  { stage: "contract", control: "Expediente completo antes de generar contrato", area: "Jurídica" },
  { stage: "document", control: "Plantilla institucional preservada", area: "Plataforma" },
  { stage: "review", control: "Historial de versiones por usuario y fecha", area: "Control Interno" },
  { stage: "archive", control: "Bitácora y archivo centralizados", area: "Control Interno" },
];

const areaStyles = {
  "Contratación": { bg: "bg-emerald-100 dark:bg-emerald-900/30", text: "text-emerald-700 dark:text-emerald-400" },
  "Financiera": { bg: "bg-teal-100 dark:bg-teal-900/30", text: "text-teal-700 dark:text-teal-400" },
  "Jurídica": { bg: "bg-indigo-100 dark:bg-indigo-900/30", text: "text-indigo-700 dark:text-indigo-400" },
  "Plataforma": { bg: "bg-purple-100 dark:bg-purple-900/30", text: "text-purple-700 dark:text-purple-400" },
  "Control Interno": { bg: "bg-cyan-100 dark:bg-cyan-900/30", text: "text-cyan-700 dark:text-cyan-400" },
} as const;
---

<Layout
  title="Pleroma - Sistema de Gestión de Contratación Pública | CodeJairo"
  description="Sistema integral para la gestión de contratación pública. Angular, Node.js, PostgreSQL, AWS S3. Generación automática de documentos contractuales."
>
  <main class="relative overflow-hidden bg-gradient-to-b from-indigo-50 via-white to-purple-50/70 dark:from-zinc-950 dark:via-zinc-900 dark:to-zinc-950">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div class="absolute -top-28 -left-24 w-80 h-80 rounded-full bg-indigo-400/20 dark:bg-indigo-500/10 blur-3xl"></div>
      <div class="absolute top-[30%] -right-20 w-72 h-72 rounded-full bg-purple-400/20 dark:bg-purple-500/10 blur-3xl"></div>
      <div class="absolute bottom-[-6rem] left-1/3 w-96 h-96 rounded-full bg-cyan-400/20 dark:bg-cyan-500/10 blur-3xl"></div>
    </div>
    <PleromaHero deploymentUrl={DEPLOYMENT_URL} />

    <!-- El Problema -->
    <section class="relative z-10 py-12 md:py-16 lg:py-20 px-6 sm:px-12 lg:px-24 bg-transparent" data-aos="fade-up" data-aos-duration="420">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <span class="text-sm font-bold text-indigo-500 uppercase tracking-wider">Contexto</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-zinc-900 dark:text-white mt-2">
            El Problema
          </h2>
        </div>
        
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
              En muchas entidades, la contratación pública combina archivos dispersos,
              documentos manuales y poca trazabilidad entre CDP, contratistas y contratos.
              Eso aumenta tiempos de gestión y riesgo de errores operativos.
            </p>
            <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
              <strong>Pleroma</strong> se diseñó para trabajar ese proceso de punta a punta
              desde una sola aplicación, manteniendo reglas claras y control documental.
            </p>
            <div class="p-4 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl border border-indigo-200 dark:border-indigo-800">
              <p class="text-indigo-800 dark:text-indigo-300 font-medium">
                La prioridad del proyecto es simple: menos reproceso, mejor seguimiento
                y documentos consistentes generados desde datos confiables.
              </p>
            </div>
          </div>
          
          <div class="space-y-4">
            <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-6">Desafíos que resuelve:</h3>
            <div class="grid gap-3">
              {challenges.map((item) => (
                <div class="flex items-start gap-4 p-4 bg-zinc-50 dark:bg-zinc-800 rounded-xl hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors">
                  <div class="w-8 h-8 flex-shrink-0 rounded-lg bg-indigo-500/10 flex items-center justify-center mt-0.5">
                    <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-zinc-900 dark:text-white">{item.title}</p>
                    <p class="text-sm text-zinc-600 dark:text-zinc-400">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="relative z-10 px-6 sm:px-12 -mt-1 mb-1" aria-hidden="true">
      <div class="md:hidden mx-auto max-w-5xl opacity-75">
        <svg viewBox="0 0 400 52" class="w-full h-12 text-indigo-500/45 dark:text-indigo-400/35" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 26C44 6 82 46 120 26C158 6 196 46 234 26C272 6 310 46 348 26C365 17 379 17 394 26" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
          <circle cx="392" cy="26" r="4" fill="currentColor" />
          <circle cx="397" cy="23" r="1.2" fill="currentColor" />
        </svg>
      </div>
      <div class="hidden md:block mx-auto max-w-6xl opacity-70">
        <svg viewBox="0 0 800 36" class="w-full h-8 text-indigo-500/45 dark:text-indigo-400/35" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 18C88 4 128 32 208 18C288 4 328 32 408 18C488 4 528 32 608 18C688 4 728 32 792 18" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
        </svg>
      </div>
    </div>

    <!-- Recorrido por el Sistema -->
    <section class="relative z-10 py-12 md:py-16 lg:py-20 px-6 sm:px-12 lg:px-24 bg-transparent" data-aos="fade-up" data-aos-duration="420">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <span class="text-sm font-bold text-indigo-500 uppercase tracking-wider">Funcionalidades</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-zinc-900 dark:text-white mt-2">
            Recorrido por el Sistema
          </h2>
          <p class="text-xl text-zinc-600 dark:text-zinc-400 mt-4 max-w-3xl mx-auto">
            Este recorrido muestra cómo se conecta cada etapa del proceso dentro del sistema.
          </p>
        </div>

        <div class="space-y-12 md:space-y-20">
          {processSteps.map((step, index) => (
            <div class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 lg:gap-12 items-center`}>
              <!-- Image Section -->
              <div class="w-full lg:w-1/2">
                <div class="relative group">
                  <div class="absolute -inset-2 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-500"></div>
                  <div class="relative overflow-hidden rounded-xl shadow-2xl bg-zinc-800">
                    <div class="absolute top-4 left-4 z-10">
                      <span class="inline-flex items-center justify-center w-10 h-10 bg-indigo-500 text-white font-bold rounded-full shadow-lg">
                        {step.step}
                      </span>
                    </div>
                    <Image 
                      src={step.image} 
                      alt={step.title}
                      class="w-full h-auto object-cover"
                    />
                  </div>
                </div>
              </div>
              
              <!-- Content Section -->
              <div class="w-full lg:w-1/2 space-y-6">
                <div>
                  <span class="text-sm font-bold text-indigo-500 uppercase tracking-wider">Paso {step.step}</span>
                  <h3 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-white mt-2">
                    {step.title}
                  </h3>
                </div>
                
                <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
                  {step.description}
                </p>
                
                <div class="sm:hidden flex flex-wrap gap-2">
                  {step.features.map((feature) => (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-xs text-zinc-700 dark:text-zinc-300 leading-tight">
                      <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0"></span>
                      {feature}
                    </span>
                  ))}
                </div>

                <div class="hidden sm:grid sm:grid-cols-2 gap-3">
                  {step.features.map((feature) => (
                    <div class="flex items-center gap-3 p-3 bg-white dark:bg-zinc-800 rounded-lg border border-zinc-200 dark:border-zinc-700">
                      <svg class="w-5 h-5 text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-sm text-zinc-700 dark:text-zinc-300">{feature}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="relative z-10 px-6 sm:px-12 -mt-1 mb-1" aria-hidden="true">
      <div class="md:hidden mx-auto max-w-5xl rounded-2xl border border-indigo-500/20 bg-indigo-500/5 p-3">
        <div class="relative h-14">
          <span class="absolute left-2 right-2 top-2 border-t-2 border-dashed border-indigo-500/40"></span>
          <div class="absolute left-1/2 -translate-x-1/2 top-4 flex items-start gap-1.5">
            {"CODEJAIRO".split("").map((letter) => (
              <span class="inline-flex items-center justify-center w-6 h-7 rounded-b-md bg-indigo-500/20 border border-indigo-500/35 text-[10px] font-bold text-indigo-700 dark:text-indigo-300">
                {letter}
              </span>
            ))}
          </div>
        </div>
      </div>
      <div class="hidden md:block mx-auto max-w-6xl rounded-2xl border border-indigo-500/20 bg-indigo-500/5 px-4 py-2 opacity-80">
        <div class="flex justify-center items-center gap-2">
          {"CODEJAIRO".split("").map((letter) => (
            <span class="inline-flex items-center justify-center w-7 h-8 rounded-md bg-indigo-500/20 border border-indigo-500/35 text-xs font-bold text-indigo-700 dark:text-indigo-300">
              {letter}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Trazabilidad Contractual -->
    <section class="relative z-10 py-12 md:py-16 lg:py-20 px-6 sm:px-12 lg:px-24 bg-transparent" data-aos="fade-up" data-aos-duration="420">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <span class="text-sm font-bold text-indigo-500 uppercase tracking-wider">Trazabilidad</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-zinc-900 dark:text-white mt-2">
            Contract Compliance Trace Map
          </h2>
          <p class="mt-4 text-zinc-600 dark:text-zinc-400 max-w-2xl mx-auto">
            Ciclo completo del proceso de contratación pública: desde el registro del tercero hasta el archivo con auditoría, con puntos de control en cada etapa.
          </p>
        </div>

        <div
          role="img"
          aria-label="Mapa de trazabilidad contractual de Pleroma: seis etapas desde registro del tercero hasta archivo con auditoría y puntos de control por área en cada paso"
          class="relative"
        >
          <p class="sr-only">
            Trazabilidad contractual de Pleroma en seis etapas: 1. Registro de Tercero, 2. Certificado Presupuestal CDP, 3. Expediente Contractual, 4. Generación Documental, 5. Revisión y Firma, 6. Archivo y Auditoría.
          </p>

          <div class="absolute left-4 lg:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-indigo-400 via-purple-400 to-cyan-400 -translate-x-px" aria-hidden="true"></div>

          <div class="flex flex-col gap-10">
            {complianceStages.map((stage, index) => {
              const isEven = index % 2 === 0;
              const matrixEntry = controlMatrix.find(m => m.stage === stage.id);
              const aStyle = matrixEntry ? areaStyles[matrixEntry.area as keyof typeof areaStyles] : areaStyles["Contratación"];
              return (
                <div class={`relative flex items-start gap-6 lg:gap-0 ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}>
                  <div class="hidden lg:block lg:w-[calc(50%-2.5rem)]" aria-hidden="true"></div>

                  <div class="relative z-10 shrink-0 flex flex-col items-center lg:mx-8">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg ring-4 ring-white dark:ring-zinc-900">
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={stage.iconPath} />
                      </svg>
                    </div>
                  </div>

                  <div class="flex-1 lg:w-[calc(50%-2.5rem)] bg-zinc-50 dark:bg-zinc-800 rounded-2xl p-5 border border-zinc-200 dark:border-zinc-700 shadow-sm">
                    <div class="flex items-center gap-3 mb-3">
                      <span class="w-7 h-7 shrink-0 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white text-xs font-bold shadow">
                        {stage.step}
                      </span>
                      <h3 class="font-bold text-zinc-900 dark:text-white text-sm leading-tight">{stage.label}</h3>
                    </div>
                    <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4 leading-relaxed">{stage.description}</p>
                    <div class="border border-dashed border-indigo-400 dark:border-indigo-600 rounded-xl p-3 flex items-start gap-3">
                      <svg class="w-4 h-4 text-indigo-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                      </svg>
                      <div class="flex-1">
                        <p class="text-xs font-semibold text-indigo-700 dark:text-indigo-400 mb-0.5">
                          {stage.controlPoint}
                        </p>
                        {matrixEntry && (
                          <p class="text-xs text-zinc-500 dark:text-zinc-400">{matrixEntry.control}</p>
                        )}
                      </div>
                      {matrixEntry && (
                        <span class={`text-xs font-bold px-2 py-0.5 rounded-full shrink-0 ${aStyle.bg} ${aStyle.text}`}>
                          {matrixEntry.area}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="mt-16 bg-zinc-50 dark:bg-zinc-800 rounded-3xl p-8 border border-zinc-200 dark:border-zinc-700">
          <h3 class="text-lg font-bold text-zinc-900 dark:text-white mb-6 text-center">Matriz de Control</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {controlMatrix.map((item) => {
              const stageData = complianceStages.find(s => s.id === item.stage);
              const aStyle = areaStyles[item.area as keyof typeof areaStyles];
              return (
                <div class="flex items-start gap-3 p-3 rounded-xl bg-white dark:bg-zinc-700/50 border border-zinc-200 dark:border-zinc-600">
                  <div class="w-1.5 h-full min-h-[2rem] rounded-full bg-gradient-to-b from-indigo-400 to-purple-400 shrink-0 mt-0.5"></div>
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-semibold text-zinc-700 dark:text-zinc-300 mb-0.5 truncate">{stageData?.label}</p>
                    <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-snug">{item.control}</p>
                  </div>
                  <span class={`text-xs font-bold px-1.5 py-0.5 rounded-md shrink-0 ${aStyle.bg} ${aStyle.text}`}>
                    {item.area}
                  </span>
                </div>
              );
            })}
          </div>
          <div class="mt-6 pt-6 border-t border-zinc-200 dark:border-zinc-700 flex flex-wrap justify-center gap-x-8 gap-y-2">
            {(Object.entries(areaStyles) as [keyof typeof areaStyles, typeof areaStyles[keyof typeof areaStyles]][]).map(([area, s]) => (
              <div class="flex items-center gap-2">
                <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${s.bg} ${s.text}`}>{area}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

